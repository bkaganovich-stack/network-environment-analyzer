{
  "name": "network-environment-analyzer",
  "private": false,
  "version": "1.0.0",
  "type": "module",
  "bin": {
    "router-radar": "./bin/cli.js"
  },
  "scripts": {
    "dev:frontend": "vite",
    "dev:backend": "node server/index.js",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
